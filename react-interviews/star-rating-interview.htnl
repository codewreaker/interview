  </section>

  <!-- Hints -->

  <section>
    <h2>Hints — Read Only If Stuck</h2>
    <div class="hint-list">
      <div class="hint">
        <strong>filledStars logic:</strong> Avoid <code>arr[i] = i % 1 || 1</code> — integers always produce <code>0</code> from <code>% 1</code>, so <code>|| 1</code> always wins. Use a remainder approach: <code>remainder = starValue - i</code>, then check <code>&gt;= 1</code>, <code>&gt;= 0.5</code>, else <code>0</code>.
      </div>
      <div class="hint">
        <strong>Mouse leave flicker:</strong> Don't put <code>onMouseLeave</code> on each <code>&lt;img&gt;</code> — it fires between stars. Move it to the container <code>&lt;div&gt;</code>. Use <code>onMouseMove</code> (not <code>onMouseOver</code>) on each star for smooth half-star tracking.
      </div>
      <div class="hint">
        <strong>data-rating is 0-based:</strong> <code>data-rating={'{idx}'}</code> starts at 0. So the first star is index 0, meaning full value = <code>idx + 1</code>, half value = <code>idx + 0.5</code>.
      </div>
      <div class="hint">
        <strong>Keyboard handler:</strong> Attach <code>onKeyDown</code> to the container div (which has <code>tabIndex="0"</code>). Read and write <code>committedValue</code>, not <code>starValue</code>. Clamp: <code>Math.min(5, ...)</code> and <code>Math.max(0, ...)</code>.
      </div>
    </div>
  </section>

  <!-- Solution Structure -->

  <section>
    <h2>Solution — Reference</h2>
    <div class="code-header">
      <div class="dots">
        <div class="dot dot-r"></div>
        <div class="dot dot-y"></div>
        <div class="dot dot-g"></div>
      </div>
      <span>Rating.js — complete solution</span>
    </div>
<pre><span class="kw">import</span> React, { useMemo, useState, useEffect } <span class="kw">from</span> <span class="str">'react'</span>;
<span class="kw">import</span> <span class="str">'./Rating.css'</span>;

<span class="kw">const</span> <span class="fn">Rating</span> = ({
value = <span class="num">0</span>,
emptyIcon      = <span class="str">’/icons/stars/empty.svg’</span>,
halfFilledIcon = <span class="str">’/icons/stars/half.svg’</span>,
filledIcon     = <span class="str">’/icons/stars/filled.svg’</span>,
steps = <span class="num">1</span>,
}) => {
<span class="kw">const</span> [starValue, setStarValue]           = <span class="fn">useState</span>(value);
<span class="kw">const</span> [committedValue, setCommittedValue] = <span class="fn">useState</span>(value);

<span class="fn">useEffect</span>(() => {
<span class="fn">setStarValue</span>(value);
<span class="fn">setCommittedValue</span>(value);
}, [value]);

<span class="kw">const</span> <span class="fn">isLessThanHalf</span> = (e) => {
<span class="kw">const</span> rect = e.target.<span class="fn">getBoundingClientRect</span>();
<span class="kw">return</span> Math.<span class="fn">round</span>(Math.<span class="fn">abs</span>(e.clientX - rect.left)) <= rect.width / <span class="num">2</span>;
};

<span class="kw">const</span> filledStars = <span class="fn">useMemo</span>(() => {
<span class="kw">const</span> arr = <span class="kw">new</span> Array(<span class="num">5</span>).<span class="fn">fill</span>(<span class="num">0</span>);
<span class="kw">for</span> (<span class="kw">let</span> i = <span class="num">0</span>; i < <span class="num">5</span>; i++) {
<span class="kw">const</span> rem = starValue - i;
<span class="kw">if</span> (rem >= <span class="num">1</span>)   arr[i] = <span class="num">1</span>;
<span class="kw">else if</span> (rem >= <span class="num">0.5</span>) arr[i] = <span class="num">0.5</span>;
}
<span class="kw">return</span> arr;
}, [starValue]);

<span class="kw">const</span> <span class="fn">handleMouseMove</span> = (e) => {
<span class="kw">const</span> idx = <span class="fn">Number</span>(e.currentTarget.dataset.rating);
<span class="fn">setStarValue</span>(steps === <span class="num">0.5</span> && <span class="fn">isLessThanHalf</span>(e) ? idx + <span class="num">0.5</span> : idx + <span class="num">1</span>);
};

<span class="kw">const</span> <span class="fn">handleMouseLeave</span> = () => <span class="fn">setStarValue</span>(committedValue);

<span class="kw">const</span> <span class="fn">handleClick</span> = (e) => {
<span class="kw">const</span> idx = <span class="fn">Number</span>(e.currentTarget.dataset.rating);
<span class="kw">const</span> next = steps === <span class="num">0.5</span> && <span class="fn">isLessThanHalf</span>(e) ? idx + <span class="num">0.5</span> : idx + <span class="num">1</span>;
<span class="fn">setStarValue</span>(next);
<span class="fn">setCommittedValue</span>(next);
};

<span class="kw">const</span> <span class="fn">handleKeyDown</span> = (e) => {
<span class="kw">if</span> (e.key === <span class="str">‘ArrowRight’</span>) {
<span class="kw">const</span> n = Math.<span class="fn">min</span>(<span class="num">5</span>, committedValue + steps);
<span class="fn">setStarValue</span>(n); <span class="fn">setCommittedValue</span>(n);
} <span class="kw">else if</span> (e.key === <span class="str">‘ArrowLeft’</span>) {
<span class="kw">const</span> n = Math.<span class="fn">max</span>(<span class="num">0</span>, committedValue - steps);
<span class="fn">setStarValue</span>(n); <span class="fn">setCommittedValue</span>(n);
} <span class="kw">else if</span> (!<span class="fn">isNaN</span>(e.key) && <span class="fn">Number</span>(e.key) <= <span class="num">5</span>) {
<span class="kw">const</span> n = <span class="fn">Number</span>(e.key);
<span class="fn">setStarValue</span>(n); <span class="fn">setCommittedValue</span>(n);
}
};

<span class="kw">const</span> <span class="fn">returnSVG</span> = (val) =>
val === <span class="num">0.5</span> ? halfFilledIcon : val === <span class="num">1</span> ? filledIcon : emptyIcon;

<span class="kw">return</span> (
<span class="tag-color"><div</span>
<span class="attr">tabIndex</span>=<span class="str">“0”</span>
<span class="attr">className</span>=<span class="str">“star-rating”</span>
<span class="attr">data-testid</span>=<span class="str">“star-rating-container”</span>
<span class="attr">onMouseLeave</span>={handleMouseLeave}
<span class="attr">onKeyDown</span>={handleKeyDown}
<span class="tag-color">></span>
{filledStars.<span class="fn">map</span>((val, idx) => (
<span class="tag-color"><img</span>
<span class="attr">key</span>={idx}
<span class="attr">src</span>={<span class="fn">returnSVG</span>(val)}
<span class="attr">onMouseMove</span>={handleMouseMove}
<span class="attr">onClick</span>={handleClick}
<span class="attr">className</span>=<span class="str">“rating-image”</span>
<span class="attr">data-rating</span>={idx}
<span class="attr">data-testid</span>=<span class="str">“rating-icon”</span>
<span class="attr">alt</span>=<span class="str">“Rate”</span>
<span class="tag-color">/></span>
))}
<span class="tag-color"></div></span>
);
};

<span class="kw">export default</span> Rating;
</pre>

  </section>

</main>

<footer>
  <span>⭐ Star Rating Component — Interview Challenge</span>
  <span>React · Hooks · Accessibility · Event Handling</span>
</footer>

