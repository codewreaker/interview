<span class="cmt">// TODO 3: Implement isLessThanHalf(event) → boolean</span>
<span class="cmt">//   Uses getBoundingClientRect + clientX to detect left-half clicks.</span>
<span class="kw">const</span> <span class="fn">isLessThanHalf</span> = (event) => {
