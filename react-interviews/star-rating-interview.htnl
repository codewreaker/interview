<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Interview Challenge — Star Rating Component</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
–bg: #0a0a0f;
–surface: #111118;
–surface2: #18181f;
–border: #2a2a38;
–accent: #f0b429;
–accent2: #e8834a;
–text: #e8e8f0;
–muted: #6b6b80;
–pass: #3ecf8e;
–fail: #f87171;
–code-bg: #0d0d14;
}

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Syne’, sans-serif;
line-height: 1.7;
min-height: 100vh;
}

/* ── Header ── */
header {
border-bottom: 1px solid var(–border);
padding: 48px 64px 40px;
position: relative;
overflow: hidden;
}
header::before {
content: ‘’;
position: absolute;
inset: 0;
background: radial-gradient(ellipse 60% 80% at 80% 50%, #f0b42912, transparent);
pointer-events: none;
}

.tag {
display: inline-block;
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
letter-spacing: .12em;
text-transform: uppercase;
color: var(–accent);
border: 1px solid var(–accent);
padding: 3px 10px;
border-radius: 3px;
margin-bottom: 20px;
}

h1 {
font-size: clamp(2rem, 4vw, 3.2rem);
font-weight: 800;
letter-spacing: -.02em;
line-height: 1.1;
max-width: 680px;
}

h1 span {
background: linear-gradient(90deg, var(–accent), var(–accent2));
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
}

.meta {
margin-top: 24px;
display: flex;
gap: 24px;
flex-wrap: wrap;
}

.meta-item {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
color: var(–muted);
}
.meta-item strong { color: var(–text); }

/* ── Layout ── */
main {
max-width: 960px;
margin: 0 auto;
padding: 56px 64px;
}

section { margin-bottom: 56px; }

h2 {
font-size: 11px;
font-family: ‘JetBrains Mono’, monospace;
letter-spacing: .15em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 20px;
display: flex;
align-items: center;
gap: 12px;
}
h2::after {
content: ‘’;
flex: 1;
height: 1px;
background: var(–border);
}

h3 {
font-size: 1.1rem;
font-weight: 700;
margin-bottom: 10px;
color: var(–text);
}

p, li {
font-size: .95rem;
color: #c0c0d0;
margin-bottom: 8px;
}

ul, ol { padding-left: 20px; }
li { margin-bottom: 6px; }

/* ── Overview card ── */
.overview {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 12px;
padding: 32px;
line-height: 1.8;
}

/* ── Requirements grid ── */
.req-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
}
@media (max-width: 640px) { .req-grid { grid-template-columns: 1fr; } }

.req-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 24px;
position: relative;
}
.req-card::before {
content: attr(data-num);
position: absolute;
top: 16px;
right: 18px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–border);
}

.req-icon {
font-size: 1.3rem;
margin-bottom: 10px;
display: block;
}

/* ── Props table ── */
table {
width: 100%;
border-collapse: collapse;
font-size: .88rem;
}
th {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px;
letter-spacing: .1em;
text-transform: uppercase;
color: var(–muted);
text-align: left;
padding: 10px 14px;
border-bottom: 1px solid var(–border);
}
td {
padding: 12px 14px;
border-bottom: 1px solid #1a1a24;
vertical-align: top;
}
tr:last-child td { border-bottom: none; }
td:first-child {
font-family: ‘JetBrains Mono’, monospace;
color: var(–accent);
font-size: .85rem;
}
td:nth-child(2) {
font-family: ‘JetBrains Mono’, monospace;
color: #a78bfa;
font-size: .83rem;
}

.table-wrap {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
overflow: hidden;
}

/* ── Code blocks ── */
pre {
background: var(–code-bg);
border: 1px solid var(–border);
border-radius: 10px;
padding: 28px;
overflow-x: auto;
font-family: ‘JetBrains Mono’, monospace;
font-size: .82rem;
line-height: 1.8;
tab-size: 2;
}

.code-header {
background: var(–surface2);
border: 1px solid var(–border);
border-bottom: none;
border-radius: 10px 10px 0 0;
padding: 10px 20px;
display: flex;
align-items: center;
justify-content: space-between;
}
.code-header + pre {
border-top: none;
border-radius: 0 0 10px 10px;
}
.code-header span {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–muted);
}
.dots { display: flex; gap: 6px; }
.dot {
width: 10px; height: 10px;
border-radius: 50%;
}
.dot-r { background: #ff5f57; }
.dot-y { background: #ffbd2e; }
.dot-g { background: #28ca41; }

.kw { color: #c084fc; }
.fn { color: #60a5fa; }
.str { color: #86efac; }
.cmt { color: #4b5563; font-style: italic; }
.num { color: var(–accent); }
.tag-color { color: #f472b6; }
.attr { color: #7dd3fc; }

/* ── Test cases ── */
.test-list { display: flex; flex-direction: column; gap: 10px; }

.test-item {
display: flex;
align-items: flex-start;
gap: 14px;
padding: 16px 20px;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
font-size: .88rem;
}

.test-badge {
flex-shrink: 0;
width: 20px;
height: 20px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
font-size: 10px;
margin-top: 1px;
}
.test-badge.pass { background: #0d2e1f; color: var(–pass); border: 1px solid var(–pass); }
.test-badge.fail { background: #2a0d0d; color: var(–fail); border: 1px solid var(–fail); }

.test-group { color: var(–muted); font-size: .8rem; margin-bottom: 2px; }
.test-name { color: var(–text); }

/* ── Hints ── */
.hint-list { display: flex; flex-direction: column; gap: 10px; }
.hint {
padding: 14px 20px;
background: var(–surface);
border-left: 3px solid var(–accent);
border-radius: 0 8px 8px 0;
font-size: .9rem;
color: #c0c0d0;
}
.hint strong { color: var(–accent); }

/* ── State model ── */
.state-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
}
@media(max-width:600px){ .state-grid{ grid-template-columns:1fr; } }

.state-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 22px;
}
.state-card h4 {
font-family: ‘JetBrains Mono’, monospace;
font-size: .82rem;
color: var(–accent);
margin-bottom: 8px;
}
.state-card p { font-size: .88rem; margin: 0; }

/* ── Footer ── */
footer {
border-top: 1px solid var(–border);
padding: 32px 64px;
display: flex;
justify-content: space-between;
align-items: center;
flex-wrap: wrap;
gap: 12px;
}
footer span {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–muted);
}
</style>

</head>
<body>

<header>
  <div class="tag">Frontend Interview Challenge</div>
  <h1>Build a <span>Star Rating</span><br/>Component in React</h1>
  <div class="meta">
    <span class="meta-item"><strong>Difficulty</strong> — Mid–Senior</span>
    <span class="meta-item"><strong>Time</strong> — 45–60 min</span>
    <span class="meta-item"><strong>Skills</strong> — React Hooks · State Management · A11y · Events</span>
    <span class="meta-item"><strong>Tests</strong> — 18 total</span>
  </div>
</header>

<main>

  <!-- Overview -->

  <section>
    <h2>Overview</h2>
    <div class="overview">
      <p>
        Implement a fully functional <strong>Star Rating component</strong> in React. The component
        renders 5 stars that respond to hover, click, and keyboard input. It must support
        <strong>full-star and half-star</strong> precision, persist selections, revert gracefully on
        mouse leave, and be fully keyboard-accessible — all driven by a clean two-state model.
      </p>
    </div>
  </section>

  <!-- Requirements -->

  <section>
    <h2>Requirements</h2>
    <div class="req-grid">
      <div class="req-card" data-num="01">
        <span class="req-icon">🖱️</span>
        <h3>Hover Behaviour</h3>
        <p>Stars fill up to the hovered index. Moving the cursor to the left half of a star should preview a half-star value. Leaving the widget reverts to the last committed value.</p>
      </div>
      <div class="req-card" data-num="02">
        <span class="req-icon">💾</span>
        <h3>Persist on Click</h3>
        <p>Clicking a star commits that value. Subsequent hover/leave cycles must revert to this committed value, not the original prop. Clicking the same star again resets to 0.</p>
      </div>
      <div class="req-card" data-num="03">
        <span class="req-icon">½</span>
        <h3>Half-Star Mode</h3>
        <p>When <code>steps=0.5</code> is passed, clicking or hovering the left half of any star selects <code>idx + 0.5</code>. Right half selects <code>idx + 1</code>.</p>
      </div>
      <div class="req-card" data-num="04">
        <span class="req-icon">⌨️</span>
        <h3>Keyboard Accessibility</h3>
        <p><strong>→</strong> increases by <code>steps</code>, <strong>←</strong> decreases by <code>steps</code>. Numeric keys 1–5 jump directly. Min 0, max 5.</p>
      </div>
      <div class="req-card" data-num="05">
        <span class="req-icon">🔄</span>
        <h3>Prop Sync</h3>
        <p>If the <code>value</code> prop changes externally (optimistic UI pattern), both display and committed state must update to reflect the new prop.</p>
      </div>
      <div class="req-card" data-num="06">
        <span class="req-icon">🎨</span>
        <h3>Custom Icons</h3>
        <p>The component accepts custom SVG paths for <code>emptyIcon</code>, <code>halfFilledIcon</code>, and <code>filledIcon</code>. All icon logic must derive from the value, not be hardcoded.</p>
      </div>
    </div>
  </section>

  <!-- Props -->

  <section>
    <h2>Component Props</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Prop</th>
            <th>Type</th>
            <th>Default</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>value</td>
            <td>number</td>
            <td>0</td>
            <td>Initial rating value. Must be synced if changed by parent.</td>
          </tr>
          <tr>
            <td>emptyIcon</td>
            <td>string</td>
            <td>/icons/stars/empty.svg</td>
            <td>Path to the empty star SVG.</td>
          </tr>
          <tr>
            <td>halfFilledIcon</td>
            <td>string</td>
            <td>/icons/stars/half.svg</td>
            <td>Path to the half-filled star SVG.</td>
          </tr>
          <tr>
            <td>filledIcon</td>
            <td>string</td>
            <td>/icons/stars/filled.svg</td>
            <td>Path to the filled star SVG.</td>
          </tr>
          <tr>
            <td>steps</td>
            <td>number</td>
            <td>1</td>
            <td>Increment size. Pass <code>0.5</code> to enable half-star precision.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Starter Code -->

  <section>
    <h2>Starter Code</h2>
    <div class="code-header">
      <div class="dots">
        <div class="dot dot-r"></div>
        <div class="dot dot-y"></div>
        <div class="dot dot-g"></div>
      </div>
      <span>Rating.js</span>
    </div>
<pre><span class="kw">import</span> React, { useMemo, useState, useEffect } <span class="kw">from</span> <span class="str">'react'</span>;
