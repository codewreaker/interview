};

<span class="cmt">// TODO 4: Derive filledStars array from starValue using useMemo.</span>
<span class="cmt">//   Result: array of 5 items, each 0 | 0.5 | 1</span>
<span class="cmt">//   Hint: use a remainder approach — avoid arr[i] = i % 1 || 1</span>
<span class="kw">const</span> filledStars = <span class="fn">useMemo</span>(() => {
<span class="cmt">// your code here</span>
}, [starValue]);

<span class="cmt">// TODO 5: handleMouseMove — updates display state only, respects `steps`</span>
<span class="cmt">// TODO 6: handleMouseLeave — reverts display to last committed value</span>
<span class="cmt">// TODO 7: handleClick — commits the new value (both states)</span>
<span class="cmt">// TODO 8: handleKeyDown — ArrowRight, ArrowLeft, numeric 1-5, respects steps</span>

<span class="cmt">// TODO 9: returnSVG(val) — maps 0 → empty, 0.5 → half, 1 → filled</span>

<span class="kw">return</span> (
<span class="tag-color"><div</span>
<span class="attr">tabIndex</span>=<span class="str">“0”</span>
<span class="attr">className</span>=<span class="str">“star-rating”</span>
<span class="attr">data-testid</span>=<span class="str">“star-rating-container”</span>
<span class="cmt">{/* attach the right handlers here */}</span>
<span class="tag-color">></span>
<span class="cmt">{/* render filledStars.map(…) */}</span>
<span class="cmt">{/* each img needs: src, onMouseMove, onClick, data-rating, data-testid=“rating-icon” */}</span>
<span class="tag-color"></div></span>
);
};

<span class="kw">export default</span> Rating;
</pre>

  </section>

  <!-- State Model -->

  <section>
    <h2>State Model</h2>
    <div class="state-grid">
      <div class="state-card">
        <h4>starValue — display state</h4>
        <p>Changes on every <code>onMouseMove</code>. This is what <code>filledStars</code> derives from. It is ephemeral — never persisted on its own.</p>
      </div>
      <div class="state-card">
        <h4>committedValue — saved state</h4>
        <p>Only changes on <strong>click</strong> or <strong>keypress</strong>. <code>handleMouseLeave</code> always resets <code>starValue</code> back to this — not to the prop.</p>
      </div>
    </div>
  </section>

  <!-- Test Cases -->

  <section>
    <h2>Test Cases — 18 Total</h2>
    <div class="test-list">

```
